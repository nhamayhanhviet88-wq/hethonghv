

        kpiRenderLeaderboard(lbEl, advData);
        kpiRenderTeamCompare(tcEl, mainData, advData);
    } catch(e) {
        console.error('Dashboard embed error:', e.message || e);
        if (lbEl) lbEl.innerHTML = '<div style="padding:20px;color:#ef4444;text-align:center">Unable to load</div>';
    }
}

function kpiTrend(cur, prev) {
    if (prev == null || prev === 0) return cur > 0 ? '<span style="color:#10b981;font-size:10px;font-weight:700">NEW</span>' : '';
    var diff = cur - prev;
    if (diff === 0) return '<span style="color:#6b7280;font-size:10px">-</span>';
    var pct = Math.round(100 * diff / prev);
    if (diff > 0) return '<span style="color:#10b981;font-size:10px;font-weight:700">+' + pct + '%</span>';
    return '<span style="color:#ef4444;font-size:10px;font-weight:700">' + pct + '%</span>';
}

function kpiRenderLeaderboard(el, data) {
    var lbObj = data && data.leaderboard;
    var allEmp = data && data.allEmployees;
    var convMap = (data && data.conversionMap) || {};
    if (!lbObj && (!allEmp || allEmp.length === 0)) { el.innerHTML = ''; return; }
    var medals = ['\uD83E\uDD47','\uD83E\uDD48','\uD83E\uDD49'];
    window.kpiDashSortLB = function(metric) {
        _kpiDashSort = metric;
        var lbEl2 = document.getElementById('kpiLeaderboard');
        if (lbEl2 && window._kpiAdvData) kpiRenderLeaderboard(lbEl2, window._kpiAdvData);
    };
    window._kpiAdvData = data;
    var lb;
    if (lbObj) {
        if (_kpiDashSort === 'orders') lb = lbObj.by_orders || allEmp || [];
        else if (_kpiDashSort === 'affiliate') lb = lbObj.by_affiliate || allEmp || [];
        else if (_kpiDashSort === 'retention') lb = lbObj.by_retention || allEmp || [];
        else lb = lbObj.by_revenue || allEmp || [];
    } else { lb = Array.isArray(allEmp) ? [].concat(allEmp) : []; }
    var tabs = [{key:'revenue',icon:'\uD83D\uDCB0',label:'Doanh S\u1ED1'},{key:'orders',icon:'\uD83D\uDCE6',label:'\u0110\u01A1n H\u00E0ng'},{key:'affiliate',icon:'\uD83E\uDD1D',label:'TK Affiliate'},{key:'retention',icon:'\uD83D\uDD01',label:'KH C\u0169 Quay L\u1EA1i'}];
    var html = '<div class="kpi-lb-section"><div class="kpi-lb-header">\uD83C\uDFC6 B\u1EA3ng X\u1EBFp H\u1EA1ng Nh\u00E2n Vi\u00EAn</div><div class="kpi-lb-tabs">';
    tabs.forEach(function(t){html+='<button class="kpi-lb-tab '+ (_kpiDashSort===t.key?'active':'') +'" onclick="kpiDashSortLB(\''+t.key+'\')">'+t.icon+' '+t.label+'</button>';});
    html += '</div><div><div class="kpi-lb-row" style="background:#f8fafc;font-weight:700;font-size:12px;color:#475569"><div>#</div><div>Nh\u00E2n vi\u00EAn</div><div style="text-align:right">\u0110\u01A1n h\u00E0ng</div><div style="text-align:right">Doanh s\u1ED1</div><div style="text-align:right">\uD83D\uDCCA C\u0110</div><div style="text-align:right">TK Aff</div><div style="text-align:right">KH c\u0169 %</div></div>';
    lb.forEach(function(emp,i){
        var rank=i<3?medals[i]:(i+1);
        var conv=convMap[emp.user_id]||{};
        var convRate=conv.rate!=null?conv.rate+'%':'\u2014';
        var convColor=conv.rate>=70?'#10b981':conv.rate>=40?'#f59e0b':'#ef4444';
        var prev=emp.prev||{};
        html+='<div class="kpi-lb-row"><div class="kpi-lb-rank">'+rank+'</div>';
        html+='<div><div class="kpi-lb-name">'+emp.name+'</div><div class="kpi-lb-team">'+(emp.team||'')+'</div></div>';
        html+='<div class="kpi-lb-val" style="color:#4338ca">'+emp.total_orders+' \u0111\u01A1n<div>'+kpiTrend(emp.total_orders,prev.total_orders)+'</div></div>';
        html+='<div class="kpi-lb-val" style="color:#059669">'+kpiDashFmtVND(emp.revenue)+'<div>'+kpiTrend(emp.revenue,prev.revenue)+'</div></div>';
        html+='<div class="kpi-lb-val" style="color:'+convColor+';font-size:12px">'+convRate+'<div>'+kpiTrend(conv.rate||0,prev.conversion_rate||0)+'</div></div>';
        html+='<div class="kpi-lb-val" style="color:#7c3aed">'+(emp.affiliate_new||0)+'<div>'+kpiTrend(emp.affiliate_new||0,prev.affiliate_new||0)+'</div></div>';
        html+='<div class="kpi-lb-val" style="color:#c2410c">'+(emp.rate||0)+'%<div>'+kpiTrend(emp.rate||0,prev.rate||0)+'</div></div>';
        html+='</div>';
    });
    html+='</div></div>';
    el.innerHTML=html;
}

function kpiRenderTeamCompare(el, data, advData) {
    var teams = advData && advData.teamComparison;
    if (!teams || teams.length === 0) { el.innerHTML = ''; return; }
    var html = '<div class="kpi-lb-section"><div class="kpi-lb-header">\uD83D\uDCCA So S\u00E1nh Team</div><div class="kpi-tc-grid">';
    teams.forEach(function(team){
        var prev=team.prev||{};
        var hb=team.total_orders>0;
        html+='<div class="kpi-tc-card"'+(hb?' style="border-color:#f59e0b;border-width:2px"':'')+'>';
        html+='<div class="kpi-tc-name">\uD83C\uDFE0 '+team.name+' <span style="font-size:12px;font-weight:500;color:#6b7280">('+(team.employee_count||0)+' NV)</span></div>';
        html+='<div class="kpi-tc-stats">';
        html+='<div class="kpi-tc-stat"><div class="kpi-tc-stat-val" style="color:#059669">'+kpiDashFmtVND(team.revenue||0)+'</div><div class="kpi-tc-stat-label">\uD83D\uDCB0 Doanh S\u1ED1</div><div style="margin-top:4px">'+kpiTrend(team.revenue||0,prev.revenue||0)+'</div></div>';
        html+='<div class="kpi-tc-stat"><div class="kpi-tc-stat-val" style="color:#4338ca">'+(team.total_orders||0)+'</div><div class="kpi-tc-stat-label">\uD83D\uDCE6 T\u1ED5ng \u0110\u01A1n</div><div style="margin-top:4px">'+kpiTrend(team.total_orders||0,prev.total_orders||0)+'</div></div>';
        html+='<div class="kpi-tc-stat"><div class="kpi-tc-stat-val" style="color:#7c3aed">'+(team.rate||0)+'%</div><div class="kpi-tc-stat-label">\uD83D\uDD01 T\u1EC8 L\u1EC6 KH C\u0168</div><div style="margin-top:4px">'+kpiTrend(team.rate||0,prev.rate||0)+'</div></div>';
        html+='<div class="kpi-tc-stat"><div class="kpi-tc-stat-val" style="color:#c2410c">'+(team.returning||0)+'</div><div class="kpi-tc-stat-label">\uD83D\uDCCB \u0110\u01A0N KH C\u0168</div><div style="margin-top:4px">'+kpiTrend(team.returning||0,prev.returning||0)+'</div></div>';
        html+='</div></div>';
    });
    html+='</div></div>';
    el.innerHTML=html;
}